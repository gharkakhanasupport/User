{
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "java.configuration.updateBuildConfiguration": "automatic",
  "files.exclude": {
    "gkk_sms_gateway/android/.gradle": true,
    "gkk_sms_gateway/android/build": true
  },
  "java.project.exclusionPaths": [
    "gkk_sms_gateway"
  ],
  "gradle.nestedProjects": false
}
